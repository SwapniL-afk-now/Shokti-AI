# Copy this file to /etc/shokti/shokti-api.env and fill values.
# Keep this file out of git when it contains real secrets.

# Required security
JWT_SECRET_KEY=replace_with_a_long_random_secret

# CORS: Netlify and optional custom frontend domain
CORS_ORIGINS=https://your-site.netlify.app,https://app.your-domain.com

# Database and app config
DATABASE_URL=sqlite:///./medical_mock.db
APP_ENV=production
UPLOAD_DIR=./uploads

# Gemini/AI settings
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_STORE_NAME=fileSearchStores/your-store
GEMINI_DAILY_LIMIT=1000
GEMINI_ENABLE_CONTEXT_CACHE=true
GEMINI_ENABLE_PRIORITY_INFERENCE=false
