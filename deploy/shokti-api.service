[Unit]
Description=Shokti FastAPI Service
After=network.target

[Service]
Type=simple
User=gpuserver3
Group=gpuserver3
WorkingDirectory=/home/gpuserver3/workspace/swapnil/Shokti-AI
EnvironmentFile=/etc/shokti/shokti-api.env
Environment=PYTHONPATH=/home/gpuserver3/workspace/swapnil/Shokti-AI
ExecStart=/home/gpuserver3/workspace/swapnil/Shokti-AI/.venv/bin/uvicorn shokti.api.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
